{
  "name": "i18n-agent-skill",
  "version": "0.1.0",
  "description": "前端项目国际化（i18n）全链路自动化工具。支持 React/Vue 源码硬编码提取、隐私脱敏、翻译同步及质量回归检测。",
  "keywords": ["i18n", "internationalization", "react", "vue", "extract", "translate", "privacy", "mcp"],
  "homepage": "https://github.com/Shirolin/i18n-agent-skill",
  "discovery": {
    "intent_prompts": [
      "我想把项目里的中文提出来做国际化",
      "帮我找找源码里还有哪些没抽离的硬编码文案",
      "同步一下多语言翻译包",
      "检查项目里的 i18n 质量",
      "i18n refactor legacy project",
      "sync i18n translations with git diff",
      "audit my i18n files for missing keys",
      "执行隐私脱敏提取"
    ],
    "triggers": {
      "file_patterns": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx", "**/*.vue", "**/locales/*.json"],
      "context_keywords": ["i18n", "translation", "locale", "internationalization", "privacy", "masking"]
    }
  },
  "mcp_entry": "python -m i18n_agent_skill"
}
