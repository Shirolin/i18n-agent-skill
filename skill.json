{
  "name": "i18n-agent-skill",
  "version": "0.1.0",
  "description": "Enterprise-grade frontend i18n automation tool. Features: AST-based extraction, Privacy Shielding, and Quality Evolution Engine. Optimized for AI agents (Cursor, Claude Code, Windsurf).",
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "react",
    "vue",
    "extract",
    "translate",
    "privacy-shield",
    "mcp",
    "cli",
    "audit",
    "optimization",
    "feedback-loop",
    "quality-evolution"
  ],
  "homepage": "https://github.com/Shirolin/i18n-agent-skill",
  "discovery": {
    "intent_prompts": [
      "audit my i18n files",
      "extract hardcoded strings for i18n",
      "sync translations for my project",
      "improve translation quality with quality audit",
      "pivot-sync based on familiar language",
      "perform privacy-masked extraction",
      "i18n health check",
      "帮我把项目里的中文提出来做国际化",
      "检查项目里的 i18n 质量",
      "同步多语言翻译包",
      "执行质量巡检",
      "跨语言参照同步"
    ],
    "triggers": {
      "file_patterns": [
        "**/*.js",
        "**/*.jsx",
        "**/*.ts",
        "**/*.tsx",
        "**/*.vue",
        "**/locales/*.json"
      ],
      "context_keywords": [
        "i18n",
        "translation",
        "locale",
        "internationalization",
        "privacy",
        "masking",
        "audit",
        "linter",
        "pivot-sync"
      ]
    }
  },
  "examples": [
    {
      "intent": "Quality health check for i18n",
      "actions": [
        "python -m i18n_agent_skill status",
        "python -m i18n_agent_skill audit-quality en"
      ]
    },
    {
      "intent": "Extract hardcoded Chinese and mask sensitive data",
      "actions": [
        "python -m i18n_agent_skill scan src/App.vue"
      ]
    }
  ],
  "mcp_entry": "python -m i18n_agent_skill"
}
