{
  "name": "i18n-agent-skill",
  "version": "0.1.0",
  "description": "前端项目国际化（i18n）全链路自动化工具。核心优势：AST 源码提取、隐私脱敏（Privacy Shield）、差异精算与质量回归保护。支持全功能 CLI 调用。",
  "keywords": ["i18n", "internationalization", "react", "vue", "extract", "translate", "privacy-shield", "mcp", "cli", "audit"],
  "homepage": "https://github.com/Shirolin/i18n-agent-skill",
  "discovery": {
    "intent_prompts": [
      "我想把项目里的中文提出来做国际化",
      "帮我找找源码里还有哪些没抽离的硬编码文案",
      "同步一下多语言翻译包",
      "检查项目里的 i18n 质量",
      "i18n refactor legacy project",
      "sync i18n translations with git diff",
      "audit my i18n files for missing keys",
      "执行隐私脱敏提取",
      "i18n 体检"
    ],
    "triggers": {
      "file_patterns": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx", "**/*.vue", "**/locales/*.json"],
      "context_keywords": ["i18n", "translation", "locale", "internationalization", "privacy", "masking", "audit", "linter"]
    }
  },
  "examples": [
    {
      "intent": "体检项目翻译质量",
      "actions": [
        "python -m i18n_agent_skill status",
        "python -m i18n_agent_skill audit en",
        "python -m i18n_agent_skill scan src --vcs"
      ]
    },
    {
      "intent": "提取 App.vue 中的硬编码中文并脱敏",
      "actions": [
        "python -m i18n_agent_skill scan src/App.vue"
      ]
    }
  ],
  "mcp_entry": "python -m i18n_agent_skill"
}
