{
  "name": "i18n-agent-skill",
  "version": "0.3.0",
  "description": "Enterprise-grade frontend i18n automation tool. Features: AST-based extraction, Privacy Shielding, and Quality Evolution Engine. Optimized for AI agents (Cursor, Claude Code, Windsurf).",
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "react",
    "vue",
    "extract",
    "translate",
    "privacy-shield",
    "mcp",
    "cli",
    "audit",
    "optimization",
    "feedback-loop",
    "quality-evolution"
  ],
  "homepage": "https://github.com/Shirolin/i18n-agent-skill",
  "discovery": {
    "intent_prompts": [
      "audit my i18n files for missing keys",
      "extract hardcoded strings from this component",
      "sync new translations for zh-CN",
      "check translation quality and typography",
      "clean up unused i18n keys",
      "pivot-sync based on a reference language",
      "i18n project health check",
      "determine project persona and tone",
      "establish project identity and translation standards",
      "promote draft translations to approved standards",
      "帮我把项目里的中文提出来做国际化",
      "检查项目里的 i18n 质量和排版",
      "分析并确立项目画像与调性",
      "将暂存的翻译内容晋升为核准标准"
    ],
    "triggers": {
      "file_patterns": [
        "**/*.js",
        "**/*.jsx",
        "**/*.ts",
        "**/*.tsx",
        "**/*.vue",
        "**/locales/*.json"
      ],
      "context_keywords": [
        "i18n",
        "translation",
        "locale",
        "internationalization",
        "privacy",
        "masking",
        "audit",
        "persona",
        "tone",
        "promotion"
      ]
    }
  },
  "examples": [
    {
      "intent": "Initial project setup and persona handshake",
      "actions": [
        "python -m i18n_agent_skill init",
        "python -m i18n_agent_skill save-persona --data \"{\\\"domain\\\":\\\"FinTech\\\",\\\"audience\\\":\\\"Professional\\\",\\\"tone\\\":\\\"Precise\\\"}\""
      ]
    },
    {
      "intent": "Full project i18n health check",
      "actions": [
        "python -m i18n_agent_skill status",
        "python -m i18n_agent_skill audit --lang all"
      ]
    },
    {
      "intent": "Extract text and promote to verified policy",
      "actions": [
        "python -m i18n_agent_skill scan --path src/components/Login.vue",
        "python -m i18n_agent_skill optimize --lang en",
        "python -m i18n_agent_skill commit --proposal en"
      ]
    }
  ],
  "mcp_entry": "python -m i18n_agent_skill"
}
